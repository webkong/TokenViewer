<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>TokenViewerWindows</RootNamespace>
    <AssemblyName>TokenViewer</AssemblyName>
    <CoreRustTarget Condition="'$(CoreRustTarget)' == ''">x86_64-pc-windows-msvc</CoreRustTarget>
    <CoreDllName>tokenviewer_core.dll</CoreDllName>
  </PropertyGroup>

  <Target Name="CopyRustCoreToOutput" AfterTargets="Build;Publish">
    <PropertyGroup>
      <CoreDllPath>$(MSBuildProjectDirectory)\..\..\core\target\$(CoreRustTarget)\release\$(CoreDllName)</CoreDllPath>
    </PropertyGroup>
    <Copy SourceFiles="$(CoreDllPath)"
          DestinationFolder="$(TargetDir)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(CoreDllPath)') and Exists('$(TargetDir)')" />
  </Target>
</Project>
