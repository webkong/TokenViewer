<Window x:Class="TokenViewerWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TokenViewer"
        Width="1240"
        Height="860"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220"
        Foreground="White">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBg" Color="#111827" />
    <SolidColorBrush x:Key="PanelBorder" Color="#243244" />
    <SolidColorBrush x:Key="MutedText" Color="#94A3B8" />
    <SolidColorBrush x:Key="Brand" Color="#059669" />

    <Style x:Key="Card" TargetType="Border">
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Background" Value="{StaticResource PanelBg}" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style TargetType="TextBlock">
      <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
      <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>
  </Window.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" Margin="0,0,0,20">
      <StackPanel>
        <TextBlock Text="TokenViewer" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Text="Track your AI token usage across devices and tools" Foreground="{StaticResource MutedText}" FontSize="13" />
      </StackPanel>

      <Button Content="Sync now"
              DockPanel.Dock="Right"
              Padding="16,10"
              Background="{StaticResource Brand}"
              BorderThickness="0"
              Foreground="White"
              FontWeight="SemiBold"
              Command="{Binding Main.SyncCommand}" />
    </DockPanel>

    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
      <TabItem Header="Overview">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,16,0,0">
            <UniformGrid Columns="4" Margin="0,0,0,16">
              <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                  <TextBlock Text="Tokens" Foreground="{StaticResource MutedText}" />
                  <TextBlock Text="{Binding Main.SummaryTokens}" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                  <TextBlock Text="Cost" Foreground="{StaticResource MutedText}" />
                  <TextBlock Text="{Binding Main.SummaryCost}" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                  <TextBlock Text="Providers" Foreground="{StaticResource MutedText}" />
                  <TextBlock Text="{Binding Main.Providers.Count}" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource Card}">
                <StackPanel>
                  <TextBlock Text="Status" Foreground="{StaticResource MutedText}" />
                  <TextBlock Text="{Binding Main.Status}" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Style="{StaticResource Card}" Grid.Column="0" Margin="0,0,12,0">
                <StackPanel>
                  <TextBlock Text="Usage" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                  <TextBlock Text="This first pass uses the Rust core directly for local usage data. Next we can layer in trend charts and live quota cards." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource Card}" Grid.Column="1">
                <StackPanel>
                  <TextBlock Text="Data Sources" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                  <ItemsControl ItemsSource="{Binding Main.Providers}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,0,0,10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="{Binding Source}" FontSize="13" />
                            <TextBlock Text="{Binding LastSync}" Foreground="{StaticResource MutedText}" FontSize="11" />
                          </StackPanel>
                          <TextBlock Grid.Column="1" Text="{Binding RecordCount}" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Providers">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,16,0,0">
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Provider Status" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TextBlock Text="This page mirrors the macOS limits view layout. Windows now fetches live quota cards where the provider exposes them, and falls back to install/status data when it cannot." Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,14" />
                <TextBlock Text="{Binding Limits.Status}" Foreground="{StaticResource MutedText}" FontSize="11" Margin="0,0,0,12" />
                <ItemsControl ItemsSource="{Binding Limits.Providers}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1" Padding="0,10,0,10">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PlanLabel}" FontSize="11" Foreground="{StaticResource MutedText}" />
                          </StackPanel>
                          <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Configured, StringFormat=Configured: {0}}" HorizontalAlignment="Right" Foreground="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding Error}" FontSize="11" Foreground="{StaticResource MutedText}" HorizontalAlignment="Right" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Settings">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="0,16,0,0">
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Theme" VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            SelectedValuePath="Key"
                            DisplayMemberPath="Value"
                            ItemsSource="{Binding Settings.ThemeOptions}"
                            SelectedValue="{Binding Settings.Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Language" VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            SelectedValuePath="Key"
                            DisplayMemberPath="Value"
                            ItemsSource="{Binding Settings.LanguageOptions}"
                            SelectedValue="{Binding Settings.Language, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Sync" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Refresh interval (min)" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1"
                           Text="{Binding Settings.SyncFrequencyMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           Padding="10,6"
                           Background="#0F172A"
                           BorderBrush="{StaticResource PanelBorder}"
                           Foreground="White" />
                </Grid>
                <CheckBox Content="Launch at startup"
                          IsChecked="{Binding Settings.LaunchAtStartup, Mode=TwoWay}" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Status" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TextBlock Text="{Binding Main.Status}" Foreground="{StaticResource MutedText}" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,14,0,0">
              <StackPanel>
                <TextBlock Text="Updates" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TextBlock Text="{Binding Updates.Status}" Foreground="{StaticResource MutedText}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding Updates.CurrentVersion, StringFormat=Current version: {0}}" Foreground="{StaticResource MutedText}" Margin="0,0,0,4" />
                <TextBlock Text="{Binding Updates.LatestVersion, StringFormat=Latest version: {0}}" Foreground="{StaticResource MutedText}" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                  <Button Content="Check now"
                          Margin="0,0,10,0"
                          Padding="14,8"
                          Background="{StaticResource Brand}"
                          BorderThickness="0"
                          Foreground="White"
                          Command="{Binding Updates.CheckCommand}" />
                  <Button Content="Install"
                          Margin="0,0,10,0"
                          Padding="14,8"
                          Command="{Binding Updates.InstallCommand}" />
                  <Button Content="Open release"
                          Padding="14,8"
                          Command="{Binding Updates.OpenReleaseCommand}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
